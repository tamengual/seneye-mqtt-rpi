# MQTT connection
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=your_user
MQTT_PASS=your_password

# Topics (optional)
MQTT_TOPIC=aquarium/seneye
MQTT_LIGHT=aquarium/seneye_light
MQTT_RAW=aquarium/seneye_raw

# Reader binary (optional; defaults to 'seneye_reader' in PATH)
# READER_BIN=/usr/local/bin/seneye_reader
